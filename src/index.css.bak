:root {
  --bg: #f8fafc;
  --card: #ffffff;
  --surface: #ffffff;
  --border: rgba(15, 23, 42, 0.08);
  --accent: #7c3aed;
  --accent-strong: #a855f7;
  --text: #0f172a;
  --muted: #475569;
  --glow: 0 10px 60px rgba(124, 58, 237, 0.18);
}

:root[data-theme='dark'] {
  --bg: #0e0f12;
  --card: #11121a;
  --surface: #12131c;
  --border: rgba(255, 255, 255, 0.08);
  --accent: #7c3aed;
  --accent-strong: #a855f7;
  --text: #e5e7eb;
  --muted: #9ca3af;
  --glow: 0 10px 80px rgba(124, 58, 237, 0.25);
}

/* Base */
html,
body {
  height: 100%;
  margin: 0;
  font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  color: var(--text);
  background: radial-gradient(circle at 20% 20%, rgba(124, 58, 237, 0.08), transparent 35%),
    radial-gradient(circle at 80% 0%, rgba(59, 130, 246, 0.08), transparent 30%),
    var(--bg);
  transition: background 200ms ease, color 200ms ease;
}

#root {
  min-height: 100%;
}

a {
  color: inherit;
  text-decoration: none;
}

button {
  font: inherit;
}

.container {
  width: min(1160px, 100% - 2.5rem);
  margin: 0 auto;
}

.layout {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.page-shell {
  flex: 1;
  padding: 2rem 0 2.5rem;
}

.site-footer {
  padding: 1.5rem 0 2rem;
  text-align: center;
  font-size: 0.95rem;
  color: var(--muted);
  border-top: 1px solid var(--border);
}

/* Header */
.wl-header {
  position: sticky;
  top: 0;
  z-index: 20;
  background: rgba(16, 17, 24, 0.82);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
  box-shadow: var(--glow);
}

:root:not([data-theme='dark']) .wl-header {
  background: rgba(255, 255, 255, 0.9);
}

.wl-header__glow {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(90deg, rgba(124, 58, 237, 0.18), rgba(59, 130, 246, 0.14));
  opacity: 0.16;
}

.wl-header__inner {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  padding: 1rem 0;
  position: relative;
  z-index: 1;
}

.wl-brand {
  display: flex;
  gap: 0.75rem;
  align-items: center;
  padding: 0.35rem 0.5rem;
  border-radius: 14px;
  transition: transform 150ms ease, box-shadow 150ms ease;
}

.wl-brand:hover {
  transform: translateY(-1px);
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
}

.wl-brand__mark {
  width: 42px;
  height: 42px;
  border-radius: 12px;
  display: grid;
  place-items: center;
  color: #0b0811;
  font-weight: 800;
  letter-spacing: 0.5px;
}

.wl-brand__mark--img img {
  width: 42px;
  height: 42px;
  object-fit: contain;
  border-radius: 10px;
}

.wl-brand__text {
  display: grid;
  gap: 2px;
}

.wl-brand__name {
  font-size: 1.1rem;
  font-weight: 700;
  letter-spacing: 0.2px;
}

.wl-brand__tagline {
  font-size: 0.85rem;
  color: var(--muted);
}

.wl-nav {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.2rem;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid var(--border);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
}

:root:not([data-theme='dark']) .wl-nav {
  background: rgba(15, 23, 42, 0.04);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4);
}

.wl-nav__link {
  padding: 0.55rem 0.85rem;
  border-radius: 999px;
  color: var(--muted);
  font-weight: 600;
  letter-spacing: 0.1px;
  transition: color 120ms ease, background 120ms ease;
}

.wl-nav__link:hover {
  color: var(--text);
  background: rgba(255, 255, 255, 0.05);
}

.wl-nav__link--active {
  background: linear-gradient(120deg, rgba(124, 58, 237, 0.18), rgba(59, 130, 246, 0.16));
  color: #fff;
  border: 1px solid rgba(255, 255, 255, 0.12);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
}

:root:not([data-theme='dark']) .wl-nav__link--active {
  color: #0f172a;
  border-color: rgba(124, 58, 237, 0.35);
  box-shadow: 0 8px 24px rgba(124, 58, 237, 0.25);
}

.wl-actions {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.wl-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.4rem;
  padding: 0.6rem 0.95rem;
  border-radius: 12px;
  border: 1px solid var(--border);
  background: rgba(255, 255, 255, 0.04);
  color: var(--text);
  font-weight: 600;
  cursor: pointer;
  transition: transform 120ms ease, background 120ms ease, border 120ms ease, box-shadow 120ms ease;
}

.wl-btn:hover {
  transform: translateY(-1px);
  background: rgba(255, 255, 255, 0.06);
  border-color: rgba(255, 255, 255, 0.14);
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
}

.wl-btn--primary {
  background: linear-gradient(135deg, var(--accent), var(--accent-strong));
  border-color: transparent;
  color: #0b0811;
  box-shadow: 0 10px 40px rgba(124, 58, 237, 0.35);
}

.wl-btn--primary:hover {
  transform: translateY(-1px);
  box-shadow: 0 12px 50px rgba(124, 58, 237, 0.45);
}

.wl-btn--ghost {
  background: transparent;
  border-color: var(--border);
  color: var(--muted);
}

.wl-user {
  display: flex;
  align-items: center;
  gap: 0.65rem;
}

.wl-avatar {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid var(--border);
  display: grid;
  place-items: center;
  font-weight: 700;
  letter-spacing: 0.5px;
}

:root:not([data-theme='dark']) .wl-avatar {
  background: rgba(124, 58, 237, 0.08);
}

.wl-user__meta {
  display: grid;
  gap: 2px;
}

.wl-user__email {
  font-size: 0.9rem;
  color: var(--text);
}

/* Language dropdown */
.wl-lang {
  position: relative;
  display: inline-flex;
  border: none;
  background: transparent;
  padding: 0;
}

.wl-lang__trigger {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.55rem 0.75rem;
  border-radius: 12px;
  border: 1px solid var(--border);
  background: rgba(255, 255, 255, 0.05);
  color: var(--text);
  font-weight: 700;
  letter-spacing: 0.15px;
  cursor: pointer;
  outline: none;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
}

.wl-lang__chevron {
  font-size: 0.8rem;
  color: var(--muted);
}

.wl-lang__menu {
  position: absolute;
  top: calc(100% + 6px);
  right: 0;
  min-width: 160px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  box-shadow: 0 18px 40px rgba(0, 0, 0, 0.32);
  padding: 0.35rem;
  display: grid;
  gap: 4px;
  z-index: 30;
}

.wl-lang__option {
  width: 100%;
  text-align: left;
  padding: 0.55rem 0.75rem;
  border: 1px solid transparent;
  border-radius: 10px;
  background: transparent;
  color: var(--text);
  cursor: pointer;
}

.wl-lang__option:hover {
  background: rgba(255, 255, 255, 0.06);
}

.wl-lang__option--active {
  background: rgba(124, 58, 237, 0.18);
  border-color: rgba(124, 58, 237, 0.35);
}

/* Theme toggle */
.wl-theme {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.55rem 0.75rem;
  border-radius: 12px;
  border: 1px solid var(--border);
  background: rgba(255, 255, 255, 0.04);
  color: var(--text);
  font-weight: 700;
  cursor: pointer;
}

.wl-theme__icon {
  font-size: 1rem;
}

.wl-theme__label {
  font-size: 0.9rem;
}

/* Grid utilities */
.grid {
  display: grid;
  gap: 1rem;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
}

.visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  margin: -1px;
  padding: 0;
  border: 0;
  clip: rect(0 0 0 0);
  overflow: hidden;
}

@media (max-width: 900px) {
  .wl-header__inner {
    flex-wrap: wrap;
    align-items: flex-start;
  }

  .wl-actions {
    width: 100%;
    justify-content: flex-end;
    gap: 0.5rem;
    margin-left: 0;
    flex-wrap: wrap;
  }

  .wl-nav {
    order: 3;
    width: 100%;
    justify-content: center;
  }

  .wl-brand {
    padding: 0;
  }
}

@media (max-width: 640px) {
  .wl-header__inner {
    gap: 0.75rem;
  }

  .wl-brand__tagline {
    display: none;
  }

  .wl-user__email {
    font-size: 0.85rem;
    color: var(--muted);
  }
}
/* Hero */
.wl-hero {
  display: grid;
  gap: 1.5rem;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  padding: 2rem 0 1rem;
  align-items: center;
}

.wl-hero__copy h1 {
  margin: 0.15rem 0;
  font-size: clamp(2.2rem, 4vw, 2.8rem);
}

.wl-hero__lead {
  margin: 0.5rem 0 1.25rem;
  max-width: 620px;
  color: var(--muted);
  line-height: 1.6;
}

.wl-hero__actions {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.wl-hero__stats {
  margin-top: 1.5rem;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
  gap: 0.75rem;
}

.wl-stat {
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 0.85rem 1rem;
  background: var(--card);
}

.wl-stat__value {
  font-weight: 800;
  font-size: 1.25rem;
}

.wl-stat__label {
  color: var(--muted);
  font-size: 0.9rem;
}

.wl-hero__card {
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 1.25rem;
  background: var(--card);
  display: grid;
  gap: 0.5rem;
  box-shadow: 0 18px 40px rgba(0, 0, 0, 0.12);
}

.wl-hero__card h3 {
  margin: 0;
  font-size: 1.3rem;
}

.wl-hero__card p {
  margin: 0;
  color: var(--muted);
}

.wl-hero__chips {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.wl-hero__card-header {
  display: flex;
  align-items: center;
  gap: 0.35rem;
}

.wl-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--accent);
}

/* Sections */
.wl-section {
  padding: 1.5rem 0 2rem;
}

.wl-section__head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
}

.wl-link {
  color: var(--accent);
  font-weight: 600;
}

.wl-center {
  display: flex;
  justify-content: center;
  padding: 2rem 0;
}

.wl-error {
  color: #ef4444;
}

.wl-features {
  display: grid;
  gap: 1rem;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
}

.wl-feature {
  padding: 1.1rem 1.2rem;
  border: 1px solid var(--border);
  border-radius: 12px;
  background: var(--card);
}

.wl-feature h3 {
  margin: 0 0 0.35rem;
}

.wl-feature p {
  margin: 0;
  color: var(--muted);
}

/* Pills & chips */
.wl-pill {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.35rem 0.75rem;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: rgba(255, 255, 255, 0.05);
  color: var(--text);
  font-weight: 700;
  letter-spacing: 0.2px;
}

.wl-pill--soft {
  background: rgba(124, 58, 237, 0.12);
  border-color: rgba(124, 58, 237, 0.35);
}

.wl-chip {
  display: inline-flex;
  align-items: center;
  padding: 0.3rem 0.65rem;
  border-radius: 10px;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid var(--border);
  font-weight: 600;
  color: var(--text);
}

/* Buttons */
.wl-btn--lg {
  padding: 0.85rem 1.35rem;
}
.product-card {
  border: 1px solid var(--border);
  border-radius: 0.75rem;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  background: var(--card);
  color: var(--text);
  text-decoration: none;
}

.product-card__image {
  height: 160px;
  background: var(--surface);
}

.product-card__body {
  padding: 1rem;
}

.product-card__price {
  margin: 0.5rem 0 0;
  font-weight: 600;
  font-size: 1rem;
}
.product-card {
  border: 1px solid var(--border);
  border-radius: 16px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  background: var(--card);
  color: var(--text);
  text-decoration: none;
  box-shadow: 0 10px 28px rgba(0, 0, 0, 0.12);
  transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
}

.product-card:hover {
  transform: translateY(-4px);
  border-color: rgba(124, 58, 237, 0.35);
  box-shadow: 0 16px 40px rgba(0, 0, 0, 0.18);
}

.product-card__image {
  position: relative;
  aspect-ratio: 4 / 3;
  background: var(--surface);
}

.product-card__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.product-card__badge {
  position: absolute;
  right: 12px;
  bottom: 12px;
  padding: 0.35rem 0.75rem;
  border-radius: 999px;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-weight: 700;
  backdrop-filter: blur(6px);
  border: 1px solid rgba(255, 255, 255, 0.18);
}

:root:not([data-theme='dark']) .product-card__badge {
  background: rgba(255, 255, 255, 0.85);
  color: #0f172a;
  border-color: rgba(15, 23, 42, 0.08);
}

.product-card__body {
  padding: 1rem 1rem 1.1rem;
  display: grid;
  gap: 0.4rem;
}

.product-card__title {
  margin: 0;
  font-size: 1.05rem;
}

.product-card__desc {
  margin: 0;
  color: var(--muted);
  line-height: 1.4;
  min-height: 2.2em;
}

.product-card__meta {
  display: flex;
  gap: 0.4rem;
  flex-wrap: wrap;
}

.product-card__pill {
  padding: 0.25rem 0.55rem;
  border-radius: 10px;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid var(--border);
  font-size: 0.85rem;
  color: var(--muted);
}

:root:not([data-theme='dark']) .product-card__pill {
  background: rgba(15, 23, 42, 0.04);
}
.product-card__actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.5rem;
  margin-top: 0.25rem;
}

.product-card__price-inline {
  font-weight: 700;
}

.wl-btn--sm {
  padding: 0.45rem 0.8rem;
  border-radius: 10px;
}

.product-card__rating {
  background: rgba(250, 204, 21, 0.16);
  border-color: rgba(250, 204, 21, 0.4);
  color: #facc15;
}

:root:not([data-theme='dark']) .product-card__rating {
  background: rgba(250, 204, 21, 0.12);
  color: #92400e;
  border-color: rgba(146, 64, 14, 0.25);
}
/* Primary button hover better contrast */
.wl-btn--primary {
  background: linear-gradient(135deg, var(--accent), var(--accent-strong));
  border-color: transparent;
  color: #0b0811;
  box-shadow: 0 10px 40px rgba(124, 58, 237, 0.35);
}

.wl-btn--primary:hover {
  transform: translateY(-1px);
  box-shadow: 0 12px 50px rgba(124, 58, 237, 0.45);
  filter: brightness(1.05);
}

:root[data-theme='dark'] .wl-btn--primary {
  color: #0b0811;
}

:root:not([data-theme='dark']) .wl-btn--primary {
  color: #0b0811;
}
/* Button contrast override */
.wl-btn--primary {
  color: #fff !important;
}
:root[data-theme='dark'] .wl-btn--primary,
:root:not([data-theme='dark']) .wl-btn--primary {
  color: #fff !important;
}
.product-card__body {
  padding: 1rem 1rem 1.1rem;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  height: 100%;
}

.product-card__title {
  margin: 0;
  font-size: 1.05rem;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-card__desc {
  margin: 0;
  color: var(--muted);
  line-height: 1.4;
  min-height: 2.4em;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-card__actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.5rem;
  margin-top: auto;
}
/* Search bar */
.wl-search {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 0.75rem;
  padding: 0.5rem;
  border: 1px solid var(--border);
  border-radius: 14px;
  background: var(--card);
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
  margin-bottom: 1rem;
}

.wl-search__input {
  width: 100%;
  padding: 0.9rem 1rem;
  border-radius: 10px;
  border: 1px solid var(--border);
  background: var(--surface);
  color: var(--text);
  font-size: 1rem;
}

.wl-search__input:focus {
  outline: 2px solid rgba(124, 58, 237, 0.35);
  border-color: rgba(124, 58, 237, 0.35);
}

.wl-search .wl-btn--primary {
  align-self: center;
}

.wl-search .wl-btn--primary:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}
.wl-search {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 0.5rem;
  padding: 0.35rem 0.4rem;
  border: 1px solid var(--border);
  border-radius: 14px;
  background: var(--card);
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
  margin-bottom: 1rem;
  align-items: center;
}

.wl-search__input {
  width: 100%;
  padding: 0.95rem 1rem;
  border-radius: 10px;
  border: 1px solid var(--border);
  background: var(--surface);
  color: var(--text);
  font-size: 1rem;
}

.wl-search .wl-btn--primary {
  padding: 0.95rem 1.15rem;
  border-radius: 10px;
  min-width: 120px;
}

.wl-search {
  column-gap: 0.5rem;
}
.wl-search {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 0.75rem;
  padding: 0.35rem;
  border: 1px solid var(--border);
  border-radius: 12px;
  background: transparent;
  box-shadow: none;
  margin-bottom: 1rem;
  align-items: center;
}

.wl-search__input {
  width: 100%;
  padding: 0.95rem 1rem;
  border-radius: 10px;
  border: 1px solid var(--border);
  background: var(--surface);
  color: var(--text);
  font-size: 1rem;
}

.wl-search__input:focus {
  outline: 2px solid rgba(124, 58, 237, 0.35);
  border-color: rgba(124, 58, 237, 0.35);
}

.wl-search button.wl-btn--primary {
  padding: 0.95rem 1.35rem;
  border-radius: 10px;
  min-width: 128px;
  box-shadow: 0 10px 30px rgba(124, 58, 237, 0.35);
}

.wl-search button.wl-btn--primary:disabled {
  opacity: 0.6;
  cursor: not-allowed;
  box-shadow: none;
}
